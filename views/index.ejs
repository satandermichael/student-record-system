<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Record System</title>
  <link rel="stylesheet" href="/style.css" />
  <script>
    const savedTheme = localStorage.getItem('theme') || 'light';
    document.documentElement.setAttribute('data-theme', savedTheme);
  </script>
</head>
<body>
  <header class="navbar">
    <a href="/" class="brand">📚 Student Record System</a>
    <div>
      <button id="theme-toggle" class="btn btn-outline" style="margin-right: 1rem;">🌙</button>
      <a href="/add" class="btn btn-primary">+ Add Student</a>
    </div>
  </header>

  <main class="container">
    <div class="analytics-grid">
      <div class="stat-card glass-panel">
        <div class="stat-title">Total Students</div>
        <div class="stat-value"><%= stats.totalStudents %></div>
      </div>
      <div class="stat-card glass-panel">
        <div class="stat-title">Unique Courses</div>
        <div class="stat-value"><%= stats.uniqueCourses %></div>
      </div>
      <div class="stat-card glass-panel" style="padding: 0.5rem 1.5rem">
        <div class="stat-title">Course Distribution</div>
        <div class="chart-container">
          <canvas id="courseChart"></canvas>
        </div>
      </div>
    </div>

    <form method="GET" action="/" class="search-bar">
      <input type="text" name="q" placeholder="Search by name or course..." value="<%= q %>" />
      <button type="submit" class="btn">Search</button>
      <a href="/export-csv<%= q ? '?q=' + encodeURIComponent(q) : '' %>" class="btn">📥 Export CSV</a>
      <button type="submit" class="btn btn-primary">Search</button>
      <% if (q) { %><a href="/" class="btn btn-outline">Clear</a><% } %>
      <input type="hidden" name="sort" value="<%= sort %>" />
      <input type="hidden" name="order" value="<%= order %>" />
    </form>

    <div class="table-container glass-panel">
      <% if (students.length === 0) { %>
        <div class="empty-state">
          <p>No students found.</p>
          <a href="/add" class="btn btn-primary">Add one now</a>
        </div>
      <% } else { %>
        <table class="student-table">
          <thead>
            <tr>
              <% 
                const getSortUrl = (col) => {
                  let newOrder = 'asc';
                  if (sort === col && order === 'asc') newOrder = 'desc';
                  return `/?sort=${col}&order=${newOrder}&q=${q}`;
                };
                const getSortIcon = (col) => {
                  if (sort !== col) return '↕';
                  return order === 'asc' ? '↓' : '↑';
                };
              %>
              <th><a href="<%= getSortUrl('name') %>">Name <span><%= getSortIcon('name') %></span></a></th>
              <th><a href="<%= getSortUrl('email') %>">Email <span><%= getSortIcon('email') %></span></a></th>
              <th><a href="<%= getSortUrl('course') %>">Course <span><%= getSortIcon('course') %></span></a></th>
              <th><a href="<%= getSortUrl('grade') %>">Grade <span><%= getSortIcon('grade') %></span></a></th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% students.forEach(function(student) { %>
              <tr>
                <td><strong><%= student.name %></strong></td>
                <td><%= student.email %></td>
                <td><span style="background: rgba(99,102,241,0.1); color: #4f46e5; padding: 4px 8px; border-radius: 4px; font-size: 0.85rem; font-weight: 600;"><%= student.course %></span></td>
                <td><strong><%= student.grade || 'N/A' %></strong></td>
                <td class="actions">
                  <a href="/view/<%= student.id %>" class="btn btn-small btn-outline">View</a>
                  <a href="/edit/<%= student.id %>" class="btn btn-small btn-primary">Edit</a>
                  <form action="/delete/<%= student.id %>" method="POST" style="display:inline"
                        onsubmit="return confirm('Are you sure you want to delete this student?');">
                    <button type="submit" class="btn btn-small btn-danger">Delete</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <% if (students.length > 0) { %>
      <div class="pagination">
        <a href="/?page=<%= pagination.page - 1 %>&limit=<%= pagination.limit %>&q=<%= q %>&sort=<%= sort %>&order=<%= order %>" 
           class="btn btn-outline <%= pagination.page === 1 ? 'btn-disabled' : '' %>">Previous</a>
        <span class="pagination-info">Page <%= pagination.page %> of <%= pagination.totalPages %></span>
        <a href="/?page=<%= pagination.page + 1 %>&limit=<%= pagination.limit %>&q=<%= q %>&sort=<%= sort %>&order=<%= order %>" 
           class="btn btn-outline <%= pagination.page >= pagination.totalPages ? 'btn-disabled' : '' %>">Next</a>
      </div>
    <% } %>

  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const themeToggleBtn = document.getElementById('theme-toggle');
    themeToggleBtn.addEventListener('click', () => {
      let currentTheme = document.documentElement.getAttribute('data-theme');
      let newTheme = currentTheme === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);
      themeToggleBtn.textContent = newTheme === 'dark' ? '☀️' : '🌙';
    });
    themeToggleBtn.textContent = document.documentElement.getAttribute('data-theme') === 'dark' ? '☀️' : '🌙';

    const courseCounts = <%- JSON.stringify(typeof courseCounts !== 'undefined' ? courseCounts : {}) %>;
    if (Object.keys(courseCounts).length > 0) {
      const ctx = document.getElementById('courseChart').getContext('2d');
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: Object.keys(courseCounts),
          datasets: [{
            data: Object.values(courseCounts),
            backgroundColor: ['#6366f1', '#ec4899', '#8b5cf6', '#14b8a6', '#f59e0b', '#3b82f6'],
            borderWidth: 0
          }]
        },
        options: { responsive: true, plugins: { legend: { position: 'right' } } }
      });
    }
  </script>
</body>
</html>
