<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Student Record System</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <header class="navbar">
    <a href="/" class="brand">📚 Student Record System</a>
    <a href="/add" class="btn btn-primary">+ Add Student</a>
  </header>

  <main class="container">
    <form method="GET" action="/" class="search-bar">
      <input type="text" name="q" placeholder="Search by name or course..." value="<%= q %>" />
      <button type="submit" class="btn">Search</button>
    </form>

    <% if (students.length === 0) { %>
      <p class="empty-state">No students found. <a href="/add">Add one now.</a></p>
    <% } else { %>
      <table class="student-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Grade</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% students.forEach(function(student) { %>
            <tr>
              <td><%= student.name %></td>
              <td><%= student.email %></td>
              <td><%= student.course %></td>
              <td><%= student.grade %></td>
              <td class="actions">
                <a href="/view/<%= student.id %>" class="btn btn-small">View</a>
                <a href="/edit/<%= student.id %>" class="btn btn-small">Edit</a>
                <form action="/delete/<%= student.id %>" method="POST" style="display:inline"
                      onsubmit="return confirm('Delete this student?');">
                  <button type="submit" class="btn btn-small btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </main>
</body>
</html>
